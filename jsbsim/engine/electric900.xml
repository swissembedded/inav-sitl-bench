<?xml version="1.0"?>
<!-- 900 W class electric motor modelled as a direct-thrust turbine:
     22 N static thrust => T/W ~ 1.4 on the 1.6 kg aerobat3d. -->
<turbine_engine name="electric900">
  <milthrust unit="LBS"> 5.0 </milthrust>
  <maxthrottle> 1.0 </maxthrottle>
  <idlethrottle> 0.0 </idlethrottle>
  <bypassratio> 0.0 </bypassratio>
  <tsfc> 0.0 </tsfc>
  <idlen1> 30 </idlen1> <idlen2> 60 </idlen2>
  <maxn1> 100 </maxn1> <maxn2> 100 </maxn2>
  <function name="IdleThrust">
    <table>
      <independentVar lookup="row">velocities/mach</independentVar>
      <tableData> 0.0 0.0
                  1.0 0.0 </tableData>
    </table>
  </function>
  <function name="MilThrust">
    <table>
      <independentVar lookup="row">velocities/mach</independentVar>
      <tableData> 0.0 1.0
                  0.1 0.85
                  0.2 0.6 </tableData>
    </table>
  </function>
</turbine_engine>
