<?xml version="1.0"?>
<!--
  aerobat3d: generic RC 3D aerobatic airplane for the INAV orientation-hold
  bench. Written from scratch for this project (GPL-3.0-or-later, see repo
  LICENSE). Deliberately simple: symmetric airfoil (flies inverted as well as
  upright), oversized control authority, thrust/weight ~1.4 so prop hang is
  possible. Thrust is a direct thruster (no propeller tables, no torque).
-->
<fdm_config name="aerobat3d" version="2.0" release="ALPHA">
  <fileheader>
    <author>Daniel Haensse</author>
    <description>Generic 1.5 m / 1.6 kg RC 3D aerobat, symmetric airfoil</description>
  </fileheader>

  <metrics>
    <wingarea unit="M2"> 0.42 </wingarea>
    <wingspan unit="M"> 1.50 </wingspan>
    <chord unit="M"> 0.28 </chord>
    <htailarea unit="M2"> 0.08 </htailarea>
    <htailarm unit="M"> 0.65 </htailarm>
    <vtailarea unit="M2"> 0.05 </vtailarea>
    <vtailarm unit="M"> 0.65 </vtailarm>
    <location name="AERORP" unit="M"> <x> 0.0 </x> <y> 0 </y> <z> 0 </z> </location>
    <location name="EYEPOINT" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0.1 </z> </location>
    <location name="VRP" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
  </metrics>

  <mass_balance>
    <ixx unit="KG*M2"> 0.045 </ixx>
    <iyy unit="KG*M2"> 0.070 </iyy>
    <izz unit="KG*M2"> 0.110 </izz>
    <emptywt unit="KG"> 1.35 </emptywt>
    <location name="CG" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
    <pointmass name="battery">
      <weight unit="KG"> 0.25 </weight>
      <location unit="M"> <x> 0.05 </x> <y> 0 </y> <z> 0 </z> </location>
    </pointmass>
  </mass_balance>

  <ground_reactions>
    <contact type="BOGEY" name="MAIN_L">
      <location unit="M"> <x> 0.05 </x> <y> -0.15 </y> <z> -0.20 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 800 </spring_coeff> <damping_coeff unit="N/M/SEC"> 60 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="MAIN_R">
      <location unit="M"> <x> 0.05 </x> <y> 0.15 </y> <z> -0.20 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 800 </spring_coeff> <damping_coeff unit="N/M/SEC"> 60 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="TAIL">
      <location unit="M"> <x> -0.60 </x> <y> 0 </y> <z> -0.05 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 400 </spring_coeff> <damping_coeff unit="N/M/SEC"> 30 </damping_coeff>
    </contact>
  </ground_reactions>

  <propulsion>
    <engine file="electric900">
      <location unit="M"> <x> 0.35 </x> <y> 0 </y> <z> 0 </z> </location>
      <thruster file="direct">
        <location unit="M"> <x> 0.35 </x> <y> 0 </y> <z> 0 </z> </location>
        <orient unit="DEG"> <pitch> 0 </pitch> <roll> 0 </roll> <yaw> 0 </yaw> </orient>
      </thruster>
    </engine>
  </propulsion>

  <flight_control name="FCS">
    <channel name="Roll">
      <aerosurface_scale name="aileron">
        <input>fcs/aileron-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/aileron-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Pitch">
      <aerosurface_scale name="elevator">
        <input>fcs/elevator-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/elevator-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Yaw">
      <aerosurface_scale name="rudder">
        <input>fcs/rudder-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/rudder-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Throttle">
      <pure_gain name="throttle">
        <input>fcs/throttle-cmd-norm</input>
        <gain>1.0</gain>
        <output>fcs/throttle-pos-norm</output>
      </pure_gain>
    </channel>
  </flight_control>

  <aerodynamics>
    <axis name="LIFT">
      <function name="aero/force/Lift_alpha">
        <description>Symmetric airfoil lift, CL0 = 0</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/alpha-rad</property> <value> 4.2 </value>
        </product>
      </function>
      <function name="aero/force/Lift_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>fcs/elevator-pos-norm</property> <value> 0.35 </value>
        </product>
      </function>
    </axis>
    <axis name="DRAG">
      <function name="aero/force/Drag_basic">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <value> 0.055 </value>
        </product>
      </function>
      <function name="aero/force/Drag_induced">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/cl-squared</property> <value> 0.09 </value>
        </product>
      </function>
    </axis>
    <axis name="SIDE">
      <function name="aero/force/Side_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/beta-rad</property> <value> -0.40 </value>
        </product>
      </function>
    </axis>
    <axis name="ROLL">
      <function name="aero/moment/Roll_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/p-aero-rad_sec</property> <value> -0.38 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_aileron">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/aileron-pos-norm</property>
          <value> 0.30 </value>
        </product>
      </function>
    </axis>
    <axis name="PITCH">
      <function name="aero/moment/Pitch_alpha">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/alpha-rad</property>
          <value> -0.30 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/ci2vel</property>
          <property>velocities/q-aero-rad_sec</property> <value> -9.0 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>fcs/elevator-pos-norm</property>
          <value> -1.10 </value>
        </product>
      </function>
    </axis>
    <axis name="YAW">
      <function name="aero/moment/Yaw_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/beta-rad</property>
          <value> 0.05 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/r-aero-rad_sec</property> <value> -0.15 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_rudder">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/rudder-pos-norm</property>
          <value> -0.14 </value>
        </product>
      </function>
    </axis>
  </aerodynamics>
</fdm_config>
