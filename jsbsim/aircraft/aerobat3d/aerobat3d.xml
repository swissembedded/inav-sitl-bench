<?xml version="1.0"?>
<!--
  aerobat3d: generic RC 3D aerobatic airplane for the INAV orientation-hold
  bench. Written from scratch for this project (GPL-3.0-or-later, see repo
  LICENSE). Deliberately simple: symmetric airfoil (flies inverted as well as
  upright), oversized control authority, thrust/weight ~1.4 so prop hang is
  possible. Thrust is an idealized external force (throttle -> body-X,
  constant with airspeed, works at hover; no propeller tables, no torque).
-->
<fdm_config name="aerobat3d" version="2.0" release="ALPHA">
  <fileheader>
    <author>Daniel Haensse</author>
    <description>Generic 1.5 m / 1.6 kg RC 3D aerobat, symmetric airfoil</description>
  </fileheader>

  <metrics>
    <wingarea unit="M2"> 0.42 </wingarea>
    <wingspan unit="M"> 1.50 </wingspan>
    <chord unit="M"> 0.28 </chord>
    <htailarea unit="M2"> 0.08 </htailarea>
    <htailarm unit="M"> 0.65 </htailarm>
    <vtailarea unit="M2"> 0.05 </vtailarea>
    <vtailarm unit="M"> 0.65 </vtailarm>
    <location name="AERORP" unit="M"> <x> 0.0 </x> <y> 0 </y> <z> 0 </z> </location>
    <location name="EYEPOINT" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0.1 </z> </location>
    <location name="VRP" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
  </metrics>

  <mass_balance>
    <ixx unit="KG*M2"> 0.045 </ixx>
    <iyy unit="KG*M2"> 0.070 </iyy>
    <izz unit="KG*M2"> 0.110 </izz>
    <emptywt unit="KG"> 1.35 </emptywt>
    <location name="CG" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
    <pointmass name="battery">
      <weight unit="KG"> 0.25 </weight>
      <location unit="M"> <x> 0.05 </x> <y> 0 </y> <z> 0 </z> </location>
    </pointmass>
  </mass_balance>

  <ground_reactions>
    <contact type="BOGEY" name="MAIN_L">
      <location unit="M"> <x> 0.05 </x> <y> -0.15 </y> <z> -0.20 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 800 </spring_coeff> <damping_coeff unit="N/M/SEC"> 60 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="MAIN_R">
      <location unit="M"> <x> 0.05 </x> <y> 0.15 </y> <z> -0.20 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 800 </spring_coeff> <damping_coeff unit="N/M/SEC"> 60 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="TAIL">
      <location unit="M"> <x> -0.60 </x> <y> 0 </y> <z> -0.05 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 400 </spring_coeff> <damping_coeff unit="N/M/SEC"> 30 </damping_coeff>
    </contact>
  </ground_reactions>

  <!-- Idealized RC thruster: throttle -> body-X force, works at any airspeed
       including hover (no propeller table, no torque, no turbine spool).
       5.0 LBS ~ 22 N static => T/W ~ 1.4 on the 1.6 kg airframe. -->
  <external_reactions>
    <force name="motor" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 5.0 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.35 </x> <y> 0 </y> <z> 0 </z> </location>
      <direction> <x> 1 </x> <y> 0 </y> <z> 0 </z> </direction>
    </force>
    <!-- Prop reaction torque: a CW prop (seen from behind) rolls the
         airframe LEFT with a moment proportional to the motor torque
         (Q = P/omega, ~0.4 Nm at full power for this class), modeled as a
         force couple: 0.4 N (0.09 LBS) at +-0.5 m span, z-down body frame,
         net moment about -x. This is the disturbance a knife-edge torque
         feedforward exists for; without it every knife/hover result is
         prettier than reality. -->
    <force name="prop-torque-r" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 0.09 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.35 </x> <y> 0.5 </y> <z> 0 </z> </location>
      <direction> <x> 0 </x> <y> 0 </y> <z> -1 </z> </direction>
    </force>
    <force name="prop-torque-l" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 0.09 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.35 </x> <y> -0.5 </y> <z> 0 </z> </location>
      <direction> <x> 0 </x> <y> 0 </y> <z> 1 </z> </direction>
    </force>
  </external_reactions>

  <flight_control name="FCS">
    <!-- With no propulsion engine, JSBSim does not auto-create the throttle
         command property; declare it so the plant can set it and the motor
         external force can read it. -->
    <property value="0.0"> fcs/throttle-cmd-norm </property>
    <channel name="Roll">
      <aerosurface_scale name="aileron">
        <input>fcs/aileron-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/aileron-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Pitch">
      <aerosurface_scale name="elevator">
        <input>fcs/elevator-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/elevator-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Yaw">
      <aerosurface_scale name="rudder">
        <input>fcs/rudder-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/rudder-pos-norm</output>
      </aerosurface_scale>
    </channel>
  </flight_control>

  <aerodynamics>
    <axis name="LIFT">
      <function name="aero/force/Lift_alpha">
        <description>Symmetric airfoil lift with stall: linear 4.2/rad up to
          15 deg (unchanged from the previous linear model, so trims stay
          valid), CLmax 1.15 at 20 deg, breaks to 0.85 at 30 deg, zero at 90.
          Without this the wing carried the plane at alpha 60-80 deg and the
          prop-hang never actually hung on the propeller.</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <table>
            <independentVar lookup="row">aero/alpha-rad</independentVar>
            <tableData>
              -3.142   0.00
              -1.571   0.00
              -0.785  -0.60
              -0.524  -0.85
              -0.349  -1.15
              -0.262  -1.10
               0.000   0.00
               0.262   1.10
               0.349   1.15
               0.524   0.85
               0.785   0.60
               1.571   0.00
               3.142   0.00
            </tableData>
          </table>
        </product>
      </function>
      <function name="aero/force/Lift_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>fcs/elevator-pos-norm</property> <value> 0.35 </value>
        </product>
      </function>
    </axis>
    <axis name="DRAG">
      <function name="aero/force/Drag_basic">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <value> 0.055 </value>
        </product>
      </function>
      <function name="aero/force/Drag_induced">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/cl-squared</property> <value> 0.09 </value>
        </product>
      </function>
      <function name="aero/force/Drag_alpha_poststall">
        <description>Flat-plate drag rise past the stall (zero in the linear
          range, ~1.3 broadside at alpha 90)</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <table>
            <independentVar lookup="row">aero/alpha-rad</independentVar>
            <tableData>
              -3.142   0.00
              -1.571   1.30
              -1.047   1.00
              -0.524   0.30
              -0.262   0.00
               0.262   0.00
               0.524   0.30
               1.047   1.00
               1.571   1.30
               3.142   0.00
            </tableData>
          </table>
        </product>
      </function>
    </axis>
    <axis name="SIDE">
      <function name="aero/force/Side_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/beta-rad</property> <value> -0.40 </value>
        </product>
      </function>
    </axis>
    <axis name="ROLL">
      <function name="aero/moment/Roll_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/p-aero-rad_sec</property> <value> -0.38 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_aileron">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/aileron-pos-norm</property>
          <value> 0.30 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_aileron_propwash">
        <description>Prop-wash aileron authority (see Pitch_elevator_propwash);
          half the 35 kts equivalent - the ailerons sit outboard, only the
          inner span rides in the wash. Without this the prop reaction
          torque rolls the hang with nothing to counter it; a real 3D
          airframe holds the torque roll on its washed full-span ailerons.</description>
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/aileron-pos-norm</property>
          <value> 13.5 </value>
        </product>
      </function>
    </axis>
    <axis name="PITCH">
      <function name="aero/moment/Pitch_alpha">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/alpha-rad</property>
          <value> -0.30 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/ci2vel</property>
          <property>velocities/q-aero-rad_sec</property> <value> -9.0 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>fcs/elevator-pos-norm</property>
          <value> -1.10 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_elevator_propwash">
        <description>Prop-wash elevator authority: thrust-proportional, so the
          tail keeps working at zero airspeed (3D airframes hang on this).
          Sized like the qbar term at ~35 kts with full throttle.</description>
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/elevator-pos-norm</property>
          <value> -18.0 </value>
        </product>
      </function>
    </axis>
    <axis name="YAW">
      <function name="aero/moment/Yaw_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/beta-rad</property>
          <value> 0.05 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/r-aero-rad_sec</property> <value> -0.15 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_rudder">
        <!-- positive rudder command = nose RIGHT, matching the INAV
             stabilized-yaw sign (the C172-style negative sign made the
             yaw loop positive feedback -> steady inverted circling) -->
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/rudder-pos-norm</property>
          <value> 0.14 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_rudder_propwash">
        <description>Prop-wash rudder authority (see Pitch_elevator_propwash)</description>
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/rudder-pos-norm</property>
          <value> 12.0 </value>
        </product>
      </function>
    </axis>
  </aerodynamics>
</fdm_config>
