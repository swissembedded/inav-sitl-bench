<?xml version="1.0"?>
<!--
  turbotimber: E-flite Turbo Timber Evolution 1.5m class STOL trainer for
  the flap/harrier bench work. Written from scratch for this project
  (GPL-3.0-or-later, see repo LICENSE), same idealized-thruster structure
  as aerobat3d. Cambered airfoil (does NOT fly inverted well - that is the
  point of a trainer), SLOTTED flaps: strong lift gain (dCL ~1.05), strong
  nose-down pitching moment (dCm -0.25) and drag - deploying them fast at
  speed produces the ballooning/trim jolt the smix speed limit exists for.
  Coefficients are handbook estimates, good for behavior, not for exact
  stall speeds. The optional leading-edge slats are NOT modeled (v1).
  Specs: span 1549 mm, S 0.361 m2, AUW ~1.6 kg, 3-blade 11x7.5 (T/W ~1).
-->
<fdm_config name="turbotimber" version="2.0" release="ALPHA">
  <fileheader>
    <author>Daniel Haensse</author>
    <description>Turbo Timber Evolution 1.5m class STOL trainer, slotted flaps</description>
  </fileheader>

  <metrics>
    <wingarea unit="M2"> 0.361 </wingarea>
    <wingspan unit="M"> 1.549 </wingspan>
    <chord unit="M"> 0.233 </chord>
    <htailarea unit="M2"> 0.070 </htailarea>
    <htailarm unit="M"> 0.60 </htailarm>
    <vtailarea unit="M2"> 0.045 </vtailarea>
    <vtailarm unit="M"> 0.60 </vtailarm>
    <location name="AERORP" unit="M"> <x> 0.0 </x> <y> 0 </y> <z> 0 </z> </location>
    <location name="EYEPOINT" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0.1 </z> </location>
    <location name="VRP" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
  </metrics>

  <mass_balance>
    <ixx unit="KG*M2"> 0.090 </ixx>
    <iyy unit="KG*M2"> 0.100 </iyy>
    <izz unit="KG*M2"> 0.170 </izz>
    <emptywt unit="KG"> 1.25 </emptywt>
    <location name="CG" unit="M"> <x> 0 </x> <y> 0 </y> <z> 0 </z> </location>
    <pointmass name="battery">
      <weight unit="KG"> 0.35 </weight>
      <location unit="M"> <x> 0.05 </x> <y> 0 </y> <z> 0 </z> </location>
    </pointmass>
  </mass_balance>

  <ground_reactions>
    <contact type="BOGEY" name="MAIN_L">
      <location unit="M"> <x> 0.05 </x> <y> -0.18 </y> <z> -0.22 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 900 </spring_coeff> <damping_coeff unit="N/M/SEC"> 70 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="MAIN_R">
      <location unit="M"> <x> 0.05 </x> <y> 0.18 </y> <z> -0.22 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 900 </spring_coeff> <damping_coeff unit="N/M/SEC"> 70 </damping_coeff>
    </contact>
    <contact type="BOGEY" name="TAIL">
      <location unit="M"> <x> -0.70 </x> <y> 0 </y> <z> -0.06 </z> </location>
      <static_friction> 0.8 </static_friction> <dynamic_friction> 0.5 </dynamic_friction>
      <spring_coeff unit="N/M"> 400 </spring_coeff> <damping_coeff unit="N/M/SEC"> 30 </damping_coeff>
    </contact>
  </ground_reactions>

  <!-- Idealized RC thruster (see aerobat3d): 3.6 LBS ~ 16 N static
       => T/W ~ 1.0 on 1.6 kg - the "Turbo" in the name is deserved. -->
  <external_reactions>
    <force name="motor" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 3.6 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.40 </x> <y> 0 </y> <z> 0 </z> </location>
      <direction> <x> 1 </x> <y> 0 </y> <z> 0 </z> </direction>
    </force>
    <force name="prop-torque-r" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 0.06 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.40 </x> <y> 0.5 </y> <z> 0 </z> </location>
      <direction> <x> 0 </x> <y> 0 </y> <z> -1 </z> </direction>
    </force>
    <force name="prop-torque-l" frame="BODY" unit="LBS">
      <function>
        <product>
          <property> fcs/throttle-cmd-norm </property>
          <value> 0.06 </value>
        </product>
      </function>
      <location unit="M"> <x> 0.40 </x> <y> -0.5 </y> <z> 0 </z> </location>
      <direction> <x> 0 </x> <y> 0 </y> <z> 1 </z> </direction>
    </force>
  </external_reactions>

  <flight_control name="FCS">
    <property value="0.0"> fcs/throttle-cmd-norm </property>
    <channel name="Roll">
      <aerosurface_scale name="aileron">
        <input>fcs/aileron-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/aileron-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Pitch">
      <aerosurface_scale name="elevator">
        <input>fcs/elevator-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/elevator-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Yaw">
      <aerosurface_scale name="rudder">
        <input>fcs/rudder-cmd-norm</input>
        <range> <min>-1</min> <max>1</max> </range>
        <output>fcs/rudder-pos-norm</output>
      </aerosurface_scale>
    </channel>
    <channel name="Flaps">
      <aerosurface_scale name="flaps">
        <input>fcs/flap-cmd-norm</input>
        <range> <min>0</min> <max>1</max> </range>
        <output>fcs/flap-pos-norm</output>
      </aerosurface_scale>
    </channel>
  </flight_control>

  <aerodynamics>
    <axis name="LIFT">
      <function name="aero/force/Lift_alpha">
        <description>Cambered STOL airfoil: CL0 0.35, slope ~4.3/rad,
          CLmax 1.30 at 14 deg, breaks to 0.80 at 30 deg. Inverted flight
          carries noticeably less (CLmin -0.80) - a trainer, not an
          aerobat.</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <table>
            <independentVar lookup="row">aero/alpha-rad</independentVar>
            <tableData>
              -3.142   0.00
              -1.571   0.00
              -0.524  -0.55
              -0.349  -0.80
              -0.175  -0.45
               0.000   0.35
               0.140   0.95
               0.244   1.30
               0.349   1.00
               0.524   0.80
               1.571   0.00
               3.142   0.00
            </tableData>
          </table>
        </product>
      </function>
      <function name="aero/force/Lift_flap">
        <description>SLOTTED flap lift: dCL 1.05 at full deflection (total
          CLmax ~2.2 class). Tapered off past the stall - a separated wing
          does not honor the flap increment.</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>fcs/flap-pos-norm</property>
          <value> 1.05 </value>
          <table>
            <independentVar lookup="row">aero/alpha-rad</independentVar>
            <tableData>
              -3.142   0.00
              -0.524   0.30
              -0.262   1.00
               0.262   1.00
               0.524   0.30
               1.571   0.00
               3.142   0.00
            </tableData>
          </table>
        </product>
      </function>
      <function name="aero/force/Lift_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>fcs/elevator-pos-norm</property> <value> 0.15 </value>
        </product>
      </function>
    </axis>
    <axis name="DRAG">
      <function name="aero/force/Drag_basic">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <value> 0.050 </value>
        </product>
      </function>
      <function name="aero/force/Drag_induced">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/cl-squared</property> <value> 0.065 </value>
        </product>
      </function>
      <function name="aero/force/Drag_flap">
        <description>Slotted flap drag at full deflection</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>fcs/flap-pos-norm</property> <value> 0.13 </value>
        </product>
      </function>
      <function name="aero/force/Drag_alpha_poststall">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <table>
            <independentVar lookup="row">aero/alpha-rad</independentVar>
            <tableData>
              -3.142   0.00
              -1.571   1.30
              -1.047   1.00
              -0.524   0.30
              -0.262   0.00
               0.262   0.00
               0.524   0.30
               1.047   1.00
               1.571   1.30
               3.142   0.00
            </tableData>
          </table>
        </product>
      </function>
    </axis>
    <axis name="SIDE">
      <function name="aero/force/Side_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>aero/beta-rad</property> <value> -0.45 </value>
        </product>
      </function>
    </axis>
    <axis name="ROLL">
      <function name="aero/moment/Roll_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/p-aero-rad_sec</property> <value> -0.42 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_aileron">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/aileron-pos-norm</property>
          <value> 0.12 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_aileron_propwash">
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/aileron-pos-norm</property>
          <value> 3.0 </value>
        </product>
      </function>
      <function name="aero/moment/Roll_dihedral">
        <description>High wing + dihedral: rolls away from sideslip - the
          self-leveling a trainer is loved for (and a 3D plane must not
          have)</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/beta-rad</property>
          <value> -0.08 </value>
        </product>
      </function>
    </axis>
    <axis name="PITCH">
      <function name="aero/moment/Pitch_zero">
        <description>Cm0: camber + tail downwash trim offset</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property>
          <value> 0.030 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_alpha">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/alpha-rad</property>
          <value> -0.55 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_flap">
        <description>Slotted flap nose-down moment - THE trim jolt: full
          deflection needs a solid chunk of up-elevator to retrim, and
          arriving fast it pitches the nose down before pilot or trim can
          follow.</description>
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>fcs/flap-pos-norm</property>
          <value> -0.25 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>aero/ci2vel</property>
          <property>velocities/q-aero-rad_sec</property> <value> -11.0 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_elevator">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/cbarw-ft</property> <property>fcs/elevator-pos-norm</property>
          <value> -0.45 </value>
        </product>
      </function>
      <function name="aero/moment/Pitch_elevator_propwash">
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/elevator-pos-norm</property>
          <value> -5.0 </value>
        </product>
      </function>
    </axis>
    <axis name="YAW">
      <function name="aero/moment/Yaw_beta">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/beta-rad</property>
          <value> 0.07 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_damp">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>aero/bi2vel</property>
          <property>velocities/r-aero-rad_sec</property> <value> -0.18 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_rudder">
        <product>
          <property>aero/qbar-psf</property> <property>metrics/Sw-sqft</property>
          <property>metrics/bw-ft</property> <property>fcs/rudder-pos-norm</property>
          <value> 0.12 </value>
        </product>
      </function>
      <function name="aero/moment/Yaw_rudder_propwash">
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <property>fcs/rudder-pos-norm</property>
          <value> 6.0 </value>
        </product>
      </function>
    </axis>
  </aerodynamics>
</fdm_config>
